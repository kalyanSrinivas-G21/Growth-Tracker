# Copy this file to .env.local for local development.
# On Vercel, add these same names under Project Settings -> Environment Variables.

# From Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET=

# Local dev value. On Vercel, set this to your deployed URL,
# e.g. https://growth-tracker-yourname.vercel.app
NEXTAUTH_URL=http://localhost:3000
